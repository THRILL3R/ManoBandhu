# ─── Database (AWS RDS PostgreSQL 15) ───────────────────────────────────────
# Replace with your actual RDS values from AWS Console → RDS → your DB instance
DATABASE_URL=postgres://YOUR_MASTER_USER:YOUR_MASTER_PASSWORD@YOUR_RDS_ENDPOINT.rds.amazonaws.com:5432/manobandhu

# ─── Redis ───────────────────────────────────────────────────────────────────
# If using ElastiCache: redis://YOUR_ELASTICACHE_ENDPOINT:6379
# For local dev only: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=manobandhu_access_secret_change_this_in_production
JWT_REFRESH_SECRET=manobandhu_refresh_secret_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:5173

# ─── SMTP / Email (Hostinger) ────────────────────────────────────────────────
EMAIL_USER=hello@manobandhu.com
EMAIL_PASS=Sanket@1201

# ─── Razorpay (optional for now — payments won't work without this) ──────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── AWS S3 (optional for now — media uploads won't work without this) ───────
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ─── OpenAI (optional for now — AI insights won't work without this) ─────────
OPENAI_API_KEY=your_openai_api_key
